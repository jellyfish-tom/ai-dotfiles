{
  "servers": {
    "Figma": {
      "url": "https://mcp.figma.com/mcp",
      "headers": {},
      "type": "http"
    },
    "codegraph": {
      "command": "codegraph",
      "args": ["serve", "--mcp", "--path", "${workspaceFolder}"],
      "type": "stdio"
    },
    "agentmemory": {
      "command": "npx",
      "args": ["-y", "@agentmemory/mcp"],
      "env": {
        "AGENTMEMORY_URL": "http://localhost:3111"
      },
      "type": "stdio"
    }
  }
}
